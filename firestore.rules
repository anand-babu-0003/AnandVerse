
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // Default: Deny all reads and writes to any collection by default
    match /{document=**} {
      allow read, write: if false;
    }

    // app_config: Site settings, about me page content.
    // Allow public read for website rendering.
    // Allow authenticated write for admin panel modifications.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // portfolioItems: The projects displayed on the portfolio.
    // Allow public read for website rendering.
    // Allow authenticated write for admin panel modifications.
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // skills: The list of skills.
    // Allow public read for website rendering.
    // Allow authenticated write for admin panel modifications.
    match /skills/{skillId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // certifications: The list of certifications.
    // Allow public read for website rendering.
    // Allow authenticated write for admin panel modifications.
    match /certifications/{certId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }
    
    // announcements: Site-wide announcements.
    // Allow public read for the live banner.
    // Allow authenticated write for admin panel modifications.
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // contactMessages: Messages from the contact form.
    // Allow anyone to create (submit the form).
    // Only allow authenticated admin to read or delete messages.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, delete: if isAuthenticated();
    }
  }
}
