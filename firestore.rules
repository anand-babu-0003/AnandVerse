
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are completely public and insecure.
    // Anyone can read, write, and delete any data in your database.
    // This should only be used for initial development and debugging.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
