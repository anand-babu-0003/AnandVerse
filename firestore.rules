rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: Allow public read-only access to most collections
    match /{document=**} {
      allow read: if true;
      allow write: if false; // Deny writes by default
    }
    
    // Allow authenticated admins to write to specific collections
    match /portfolioItems/{itemId} {
      allow write: if request.auth != null;
    }
    match /skills/{skillId} {
      allow write: if request.auth != null;
    }
    match /certifications/{certId} {
      allow write: if request.auth != null;
    }
    match /app_config/{configId} {
      allow write: if request.auth != null;
    }
    match /announcements/{announcementId} {
        allow write: if request.auth != null;
    }

    // Contact messages: Allow public to create, but only admins can read/delete
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write, delete: if request.auth != null;
    }
  }
}
