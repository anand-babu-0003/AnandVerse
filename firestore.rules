rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Publicly readable collections ---
    // Anyone can read these collections to view the public website.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Only admins can write
    }
    match /certifications/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Only admins can write
    }
    match /portfolioItems/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Only admins can write
    }
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Only admins can write
    }

    // --- Announcements ---
    // Anyone can read active announcements.
    // Only admins can create or modify announcements.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- Contact Messages ---
    // Anyone can create a contact message.
    // Only authenticated admins can read or delete them.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, delete: if isAuthenticated();
      allow update: if false; // Messages should not be updatable
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
