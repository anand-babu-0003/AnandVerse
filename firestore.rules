rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Publicly Readable & Writable Collections ---
    // These collections need to be writable from your admin panel.
    // WARNING: Since the current admin auth is basic, these are temporarily public.
    // For production, you should implement Firebase Authentication and change
    // the `allow write` rule to `if request.auth != null;`
    match /app_config/{documentId} {
      allow read, write: if true;
    }

    match /portfolioItems/{itemId} {
      allow read, write: if true;
    }

    match /skills/{skillId} {
      allow read, write: if true;
    }

    match /announcements/{announcementId} {
      allow read, write: if true;
    }

    // --- Contact Messages ---
    match /contactMessages/{messageId} {
      allow create: if true; // Anyone can submit a message
      allow read, delete: if true; // Admin can read/delete. Change to `if request.auth != null;` with Firebase Auth.
      allow update: if false; // Messages should not be editable.
    }
  }
}
