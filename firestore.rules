
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Site Settings ---
    match /app_config/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Portfolio Items ---
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Skills ---
    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // --- Certifications ---
    match /certifications/{certificationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Contact Messages ---
    match /contactMessages/{messageId} {
      allow create: if true; // Anyone can submit
      allow read, delete: if request.auth != null;
      allow update: if false;
    }

    // --- Live Users (for live visitor count) ---
    match /live_users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // --- Admins Collection (optional) ---
    match /admins/{userId} {
      allow read, write: if request.auth != null;
    }

    // --- Not Found Page Settings ---
    match /notFoundPage/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- About Me Data ---
    match /aboutMe/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Site Pages (Privacy/Terms) ---
    match /site_pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
