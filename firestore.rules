
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- PUBLIC READ, ADMIN WRITE COLLECTIONS ---
    // These collections are displayed on the public site but managed only by admins.
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null; // Covers create, update, delete
    }

    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /certifications/{certId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // --- ADMIN-ONLY READ/WRITE COLLECTIONS ---
    // Config documents that are only read via authenticated server actions.
    match /app_config/{docId} {
      allow read, write: if request.auth != null;
    }

    // --- CONTACT MESSAGES ---
    // Public can create, only admin can read/delete.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if false; // Messages should not be updatable.
    }
  }
}
