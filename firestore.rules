
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- ADMIN-WRITABLE COLLECTIONS ---
    // The admin panel's server actions are authenticated.
    // These rules allow any authenticated user to write to these collections.
    // Public read access is maintained for website content.

    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin-only writes
    }
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin-only writes
    }
    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin-only writes
    }
    match /certifications/{certId} {
      allow read: if true;
      allow write: if request.auth != null; // Admin-only writes
    }
    
    // --- SPECIALIZED COLLECTIONS ---

    // CONTACT MESSAGES: Anyone can create (submit the form), but only admins can see or delete.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
    
    // ANNOUNCEMENTS: Anyone can read, but only admins can create or update.
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // --- DEFAULT RULE ---
    // Deny all other reads/writes by default for security.
    // This rule does not apply to the paths defined above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
