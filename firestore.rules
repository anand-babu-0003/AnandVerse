rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // --- App Config (Site Settings, About Me, etc.) ---
    // Public can read, only authenticated admins should write.
    // For this app, we assume server actions are authenticated or have admin rights.
    // However, to ensure public pages work, we allow public read.
    // Write access is restricted.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can write.
    }
    
    // --- Announcements ---
    // Public can read for live banners, only authenticated can write.
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // --- Contact Messages ---
    // Public can create, only authenticated can read/delete.
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
    
    // --- Portfolio, Skills, Certifications ---
    // Public can read, only authenticated can write/delete.
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    match /skills/{skillId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    match /certifications/{certId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
